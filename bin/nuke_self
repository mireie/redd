#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../lib/redd_auth'

# Initialize session
session = ReddAuth.authenticate_or_exit

begin
  puts 'Fetching your overview...'
  overview = session.me.overview

  puts "Found #{overview.count} items in your overview"
  puts 'Deleting all items...'

  deleted_count = 0
  overview.map do |item|
    item.delete
    deleted_count += 1
  end

  puts "Successfully deleted #{deleted_count} items from your overview"
rescue StandardError => e
  puts "Error occurred: #{e.message}"
  puts e.backtrace if ENV['DEBUG']
  exit 1
end
